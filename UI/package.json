{
  "name": "warpweb",
  "version": "0.1.0",
  "description": "Web interface for filewarp",
  "scripts": {
    "start": "concurrently \"npm run dev:ui\" \"npm run dev:server\"",
    "tailwind:build": "NODE_ENV=production npx @tailwindcss/cli -i ./src/styles/config.css -o ./src/styles/global.css --minify",
    "tailwind:watch": "tailwindcss -i ./src/styles/config.css -o ./src/styles/global.css --watch",
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:server\"",
    "dev:tsc": "npx tsc",
    "dev:ui": "vite",
    "dev:server": "python ../Server/warpapp/main.py",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "preview": "vite preview"
  },
  "author": "Warp Team",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@reduxjs/toolkit": "^2.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "aos": "^3.0.0-beta.6",
    "cross-env": "^7.0.3",
    "motion": "^12.35.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.0",
    "react-icons": "^5.0.0",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.22.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "uuid": "^9.0.0",
    "vite": "^7.1.12",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "audit": "^0.0.6",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-pseudo-elements": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "eslintConfig": {
    "extends": [],
    "rules": {
      "react/jsx-filename-extension": [
        1,
        {
          "extensions": [
            ".tsx",
            ".jsx"
          ]
        }
      ],
      "react/function-component-definition": [
        2,
        {
          "namedComponents": "arrow-function"
        }
      ],
      "import/prefer-default-export": "off",
      "react/require-default-props": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "src/**/*",
    "build/**/*",
    "index.html",
    "!node_modules/",
    "!icons",
    "!dist"
  ]
}
